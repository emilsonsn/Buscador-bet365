# Copie este arquivo para .env e ajuste conforme o sistema operacional.
BET365_CDP_PORT=9222
BET365_CLOSE_ALL_CHROME=true
BET365_RESET_TABS=true
# Reinicia o robô se placar, relógio, linhas e odds não mudarem no período informado.
BET365_STALL_TIMEOUT_SECONDS=60
BET365_MAX_RESTARTS=3
BET365_RESTART_WAIT_AFTER_CLOSE_SECONDS=60
# Opcional. Em branco, usa automaticamente ~/.chrome-bet365-debug.
# BET365_CHROME_PROFILE=
BET365_HEADLESS=false
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
GOOGLE_CREDENTIALS_PATH=credentials.json
GOOGLE_SPREADSHEET_ID=
LOGS_DIRECTORY=logs
